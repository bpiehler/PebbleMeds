{
  "name": "pebble-meds",
  "version": "1.0.0",
  "author": "Britt Piehler",
  "keywords": ["pebble-app"],
  "scripts": {
    "test": "jest"
  },
  "main": "src/pkjs/app.js",
  "devDependencies": {
    "jest": "^29.0.0"
  },
  "jest": {
    "testMatch": ["**/tests/**/*.test.js"]
  },
  "pebble": {
    "uuid": "d4e8a2f0-1b3c-4d5e-8f9a-0b1c2d3e4f5a",
    "displayName": "Pebble Meds",
    "companyName": "Britt Piehler",
    "versionLabel": "1.0",
    "sdkVersion": "3",
    "targetPlatforms": ["aplite", "basalt", "chalk", "diorite", "emery", "flint", "gabbro"],
    "watchapp": {
      "watchface": false
    },
    "messageKeys": [
      "ConfigJson",
      "ChunkIndex",
      "ChunkTotal",
      "Action",
      "MedIndex",
      "DoseTs",
      "RequestSync"
    ],
    "resources": {
      "media": [
        {
          "type": "bitmap",
          "name": "IMAGE_APP_ICON",
          "file": "images/app_icon.png",
          "menuIcon": true
        },
        { "type": "bitmap", "name": "IMAGE_ICON_TAKEN",  "file": "images/icon_taken.png"  },
        { "type": "bitmap", "name": "IMAGE_ICON_SNOOZE", "file": "images/icon_snooze.png" },
        { "type": "bitmap", "name": "IMAGE_ICON_SKIP",   "file": "images/icon_skip.png"   }
      ]
    },
    "capabilities": ["configurable", "timeline_enabled"]
  }
}
